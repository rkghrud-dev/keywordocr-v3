<Window x:Class="KeywordOcr.Runner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeywordOCR Runner — C# 전용"
        Width="720" Height="700"
        MinWidth="600" MinHeight="560"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 헤더 -->
            <RowDefinition Height="Auto"/>  <!-- 파일 드롭존 -->
            <RowDefinition Height="Auto"/>  <!-- 설정 -->
            <RowDefinition Height="Auto"/>  <!-- 실행 버튼 -->
            <RowDefinition Height="*"/>     <!-- 로그 -->
            <RowDefinition Height="Auto"/>  <!-- 하단 -->
        </Grid.RowDefinitions>

        <!-- ── 헤더 ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="KeywordOCR Runner"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1E293B"/>
            <TextBlock Text="Python 없이 C#만으로 키워드 생성 + 대표이미지"
                       FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ── 파일 드롭존 ──────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                x:Name="DropZone"
                BorderBrush="#CBD5E1" BorderThickness="2"
                CornerRadius="8" Background="White"
                Height="80" Margin="0,0,0,14"
                AllowDrop="True"
                Drop="DropZone_Drop"
                DragOver="DropZone_DragOver"
                DragLeave="DropZone_DragLeave"
                Cursor="Hand"
                MouseLeftButtonDown="DropZone_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="DropHint"
                           Text="📂  Excel / CSV 파일을 드래그하거나 클릭해서 선택"
                           FontSize="13" Foreground="#64748B"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="DropFileName"
                           FontSize="12" Foreground="#2563EB"
                           HorizontalAlignment="Center" Margin="0,4,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- ── 설정 그리드 ───────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- AI 모델 -->
            <StackPanel Grid.Column="0" Grid.Row="0">
                <TextBlock Text="AI 모델" Style="{StaticResource SectionLabel}"/>
                <ComboBox x:Name="ModelCombo" SelectedIndex="0">
                    <ComboBoxItem Content="claude-haiku-4-5-20251001" Tag="claude-haiku-4-5-20251001"/>
                    <ComboBoxItem Content="claude-sonnet-4-6" Tag="claude-sonnet-4-6"/>
                    <ComboBoxItem Content="claude-opus-4-6" Tag="claude-opus-4-6"/>
                    <ComboBoxItem Content="gpt-4.1-mini" Tag="gpt-4.1-mini"/>
                    <ComboBoxItem Content="gpt-4.1" Tag="gpt-4.1"/>
                </ComboBox>
            </StackPanel>

            <!-- 이미지 폴더 -->
            <StackPanel Grid.Column="2" Grid.Row="0">
                <TextBlock Text="이미지 폴더 (선택)" Style="{StaticResource SectionLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ImgFolderBox" IsReadOnly="True"
                             Background="#F8FAFC" Foreground="#64748B"/>
                    <Button Grid.Column="2" Content="찾기"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="10,6"
                            Click="BrowseImgFolder_Click"/>
                </Grid>
            </StackPanel>

            <!-- Anthropic API 키 -->
            <StackPanel Grid.Column="0" Grid.Row="2">
                <TextBlock Text="Anthropic API Key" Style="{StaticResource SectionLabel}"/>
                <PasswordBox x:Name="ApiKeyBox"
                             BorderBrush="#E2E8F0" BorderThickness="1"
                             Padding="8,6" FontSize="12"
                             MaxLength="200"/>
            </StackPanel>

            <!-- Tesseract 경로 -->
            <StackPanel Grid.Column="2" Grid.Row="2">
                <TextBlock Text="Tesseract 경로" Style="{StaticResource SectionLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TessPathBox"
                             Text="C:\Program Files\Tesseract-OCR"/>
                    <Button Grid.Column="2" Content="찾기"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="10,6"
                            Click="BrowseTess_Click"/>
                </Grid>
            </StackPanel>

            <!-- 옵션 체크박스 -->
            <StackPanel Grid.Column="0" Grid.Row="4"
                        Orientation="Horizontal" HorizontalAlignment="Left">
                <CheckBox x:Name="ChkOcr"     Content="OCR"      IsChecked="True" Margin="0,0,16,0"/>
                <CheckBox x:Name="ChkListing" Content="대표이미지" IsChecked="True" Margin="0,0,16,0"/>
                <CheckBox x:Name="ChkBMarket" Content="B마켓 동시생성" IsChecked="True"/>
            </StackPanel>
        </Grid>

        <!-- ── 실행 버튼 ─────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,14">
            <Button x:Name="BtnRunAll"
                    Content="▶  전체 실행"
                    Style="{StaticResource PrimaryBtn}"
                    Click="BtnRunAll_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnRunKw"
                    Content="키워드만"
                    Style="{StaticResource SecondaryBtn}"
                    Click="BtnRunKw_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnRunImg"
                    Content="대표이미지만"
                    Style="{StaticResource SecondaryBtn}"
                    Click="BtnRunImg_Click" Margin="0,0,0,0"/>
            <Button x:Name="BtnStop"
                    Content="■  중지"
                    Style="{StaticResource SecondaryBtn}"
                    IsEnabled="False"
                    Foreground="#DC2626"
                    Click="BtnStop_Click" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- ── 로그 ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="6" Background="White"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 로그 헤더 -->
                <Border Grid.Row="0"
                        Background="#F1F5F9"
                        CornerRadius="6,6,0,0"
                        Padding="10,6">
                    <Grid>
                        <TextBlock Text="진행 상황"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   VerticalAlignment="Center"/>
                        <Button Content="지우기"
                                HorizontalAlignment="Right"
                                Style="{StaticResource SecondaryBtn}"
                                Padding="8,3" FontSize="10"
                                Click="BtnClearLog_Click"/>
                    </Grid>
                </Border>

                <!-- 로그 텍스트 -->
                <ScrollViewer Grid.Row="1"
                              x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogBox"
                               FontFamily="Consolas, Courier New"
                               FontSize="11.5"
                               Foreground="#1E293B"
                               Padding="10,8"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── 하단 상태바 ───────────────────────────────────────────────── -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 프로그레스바 -->
            <ProgressBar x:Name="ProgressBar"
                         Grid.Column="0"
                         Height="8"
                         Background="#E2E8F0"
                         Foreground="#2563EB"
                         Minimum="0" Maximum="100" Value="0"
                         VerticalAlignment="Center"/>

            <!-- 퍼센트 -->
            <TextBlock x:Name="ProgressLabel"
                       Grid.Column="1"
                       FontSize="11" Foreground="#64748B"
                       VerticalAlignment="Center" Margin="8,0"/>

            <!-- 결과 폴더 열기 -->
            <Button x:Name="BtnOpenResult"
                    Grid.Column="3"
                    Content="결과 폴더 열기"
                    Style="{StaticResource SecondaryBtn}"
                    Padding="12,5" FontSize="11"
                    IsEnabled="False"
                    Click="BtnOpenResult_Click"/>
        </Grid>
    </Grid>
</Window>
